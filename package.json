    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^5.1.1",
    "jsdom": "^25.0.1",
    "qrcode": "^1.5.4",
    "typescript": "^5.7.2",
    "vite": "^7.3.5",
    "vitest": "^4.1.9"
  }
}
